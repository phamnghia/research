---
/**
 * Demo live: đọc SSE (JSON mỗi dòng), log + line chart latency.
 * Endpoint mặc định `/api/demo-sse` — chỉ có khi chạy `npm run dev` (Vite plugin).
 */
interface Props {
  streamUrl?: string;
  maxPoints?: number;
}

const { streamUrl = '/api/demo-sse', maxPoints = 32 } = Astro.props;
---

<div class="live-sse-panel" data-live-sse data-stream-url={streamUrl} data-max-points={maxPoints}>
  <div class="live-sse-panel__toolbar">
    <span class="live-sse-panel__badge" data-sse-status>Đang kết nối…</span>
    <span class="live-sse-panel__meta" data-sse-url></span>
  </div>
  <p class="live-sse-panel__hint">
    Mock SSE chỉ phục vụ trong <code>npm run dev</code>. Với <code>astro build</code> + host tĩnh, kết nối sẽ lỗi — cần adapter Node/edge hoặc API riêng.
  </p>
  <div class="live-sse-panel__grid">
    <pre class="live-sse-panel__log" data-sse-log></pre>
    <div class="live-sse-panel__chartwrap">
      <canvas></canvas>
    </div>
  </div>
</div>

<script>
  import { bootLiveSseDemos } from '../lib/liveSseDemoBoot.ts';
  bootLiveSseDemos();
</script>

<style>
  .live-sse-panel {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px 18px;
    background: var(--bg-elev);
  }
  .live-sse-panel__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 14px;
    margin-bottom: 8px;
  }
  .live-sse-panel__badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: var(--text-bright);
    border: 1px solid color-mix(in srgb, var(--accent) 35%, var(--border));
  }
  .live-sse-panel__badge[data-ok='true'] {
    background: color-mix(in srgb, var(--green) 22%, transparent);
    border-color: color-mix(in srgb, var(--green) 40%, var(--border));
  }
  .live-sse-panel__badge[data-ok='false'] {
    background: color-mix(in srgb, var(--red) 18%, transparent);
    border-color: color-mix(in srgb, var(--red) 35%, var(--border));
  }
  .live-sse-panel__meta {
    font-size: 12px;
    color: var(--text-muted);
    word-break: break-all;
  }
  .live-sse-panel__hint {
    margin: 0 0 14px;
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.55;
  }
  .live-sse-panel__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-items: stretch;
  }
  @media (max-width: 800px) {
    .live-sse-panel__grid {
      grid-template-columns: 1fr;
    }
  }
  .live-sse-panel__log {
    margin: 0;
    padding: 12px 14px;
    font-size: 11.5px;
    line-height: 1.45;
    background: var(--bg);
    border: 1px solid var(--border-soft);
    border-radius: 8px;
    color: var(--text);
    max-height: 220px;
    overflow: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .live-sse-panel__chartwrap {
    height: 220px;
    min-height: 180px;
    position: relative;
  }
</style>
