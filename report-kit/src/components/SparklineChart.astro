---
/**
 * SparklineChart — đường mini chart SVG, không dependency.
 * Dùng cho trend ngắn trong báo cáo (latency, token count theo step, …).
 */
interface Props {
  /** Chuỗi số ≥ 2 phần tử; scale theo min/max nội bộ */
  values: number[];
  caption?: string;
  /** Chiều rộng SVG (px) */
  width?: number;
  /** Chiều cao vùng vẽ (px) */
  height?: number;
}

const { values, caption, width = 200, height = 36 } = Astro.props;

const series = values.filter((n) => Number.isFinite(n));
const pad = 2;
const w = width;
const h = height;

let pathD = '';
if (series.length >= 2) {
  const min = Math.min(...series);
  const max = Math.max(...series);
  const span = max - min || 1;
  const step = (w - pad * 2) / (series.length - 1);
  pathD = series
    .map((v, i) => {
      const x = pad + i * step;
      const y = pad + (1 - (v - min) / span) * (h - pad * 2);
      return `${i === 0 ? 'M' : 'L'} ${x.toFixed(2)} ${y.toFixed(2)}`;
    })
    .join(' ');
}
---

<figure class="sparkline-chart">
  {series.length >= 2 ? (
    <svg
      class="sparkline-chart__svg"
      viewBox={`0 0 ${w} ${h}`}
      width={w}
      height={h}
      role="img"
      aria-label={caption ?? 'Sparkline'}
    >
      <path
        class="sparkline-chart__path"
        d={pathD}
        fill="none"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  ) : (
    <p class="sparkline-chart__empty">Cần ít nhất 2 điểm số hợp lệ.</p>
  )}
  {caption && <figcaption class="sparkline-chart__caption">{caption}</figcaption>}
</figure>

<style>
  .sparkline-chart {
    margin: 0;
    display: inline-block;
    vertical-align: middle;
  }
  .sparkline-chart__svg {
    display: block;
    color: var(--accent);
  }
  .sparkline-chart__path {
    stroke: currentColor;
  }
  .sparkline-chart__caption {
    margin: 6px 0 0;
    font-size: 12px;
    color: var(--text-muted);
  }
  .sparkline-chart__empty {
    margin: 0;
    font-size: 13px;
    color: var(--text-muted);
  }
</style>
