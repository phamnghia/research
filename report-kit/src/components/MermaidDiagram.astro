---
/**
 * MermaidDiagram — render Mermaid.js diagrams (flowchart, sequence, gantt, etc.)
 * Thư viện `mermaid` bundle qua Vite (`mermaidDiagramBoot.ts`), theme theo prefers-color-scheme.
 *
 * Props:
 *   - chart: string — Mermaid syntax (dùng template literal)
 *   - caption?: string
 *
 * Usage:
 *   <MermaidDiagram
 *     chart={`graph TD
 *       A[Request] --> B{Tool call?}
 *       B -- yes --> C[Execute]
 *       B -- no --> D[Return]`}
 *     caption="Agent loop decision"
 *   />
 */
interface Props {
  chart: string;
  caption?: string;
}

const { chart, caption } = Astro.props;
const uid = 'mmd-' + Math.random().toString(36).slice(2, 9);
---

<div class="mermaid-wrap">
  {caption && <p class="mmd-caption">{caption}</p>}
  <div class="mermaid-container" id={uid}>
    <pre class="mermaid-src">{chart}</pre>
    <div class="mmd-loading" aria-hidden="true">Loading diagram…</div>
  </div>
</div>

<script>
  import { bootMermaidDiagrams } from '../lib/mermaidDiagramBoot.ts';
  bootMermaidDiagrams();
</script>

<style>
  .mermaid-wrap {
    margin: 20px 0;
  }

  .mmd-caption {
    font-size: 12.5px;
    color: var(--text-muted);
    margin: 0 0 8px;
    font-style: italic;
    text-align: center;
  }

  .mermaid-container {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px;
    overflow-x: auto;
    min-height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mermaid-src {
    display: none;
  }

  .mmd-loading {
    font-size: 12.5px;
    color: var(--text-muted);
    font-style: italic;
  }

  .mmd-svg {
    width: 100%;
    text-align: center;
  }

  .mmd-svg :global(svg) {
    max-width: 100%;
    height: auto;
  }
</style>
