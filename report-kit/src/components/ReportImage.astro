---
/**
 * ReportImage — embed hình ảnh trong báo cáo với caption + source attribution.
 * Click vào ảnh để zoom lightbox (ESC hoặc click ngoài để đóng).
 *
 * Dùng khi:
 *   - Lấy diagram kiến trúc từ tài liệu tham khảo
 *   - Screenshot UI / benchmark chart từ repo / blog
 *   - Sơ đồ luồng (flow) từ whitepaper hoặc official docs
 *
 * Lưu ý:
 *   - `src` có thể là URL tuyệt đối (https://...) hoặc path tương đối trong public/
 *   - Luôn điền `alt` mô tả đầy đủ nội dung (accessibility + SEO)
 *   - `source` nên là URL gốc để credit tác giả / tổ chức
 *   - Ảnh từ GitHub raw: dùng https://raw.githubusercontent.com/...
 *   - Ảnh từ GitHub release/docs: dùng direct media URL
 */
interface Props {
  /** URL hoặc path ảnh */
  src: string;
  /** Mô tả nội dung ảnh (bắt buộc) */
  alt: string;
  /** Caption HTML hiển thị dưới ảnh (tuỳ chọn, hỗ trợ <a>, <code>, <strong>) */
  caption?: string;
  /** URL nguồn để attribution */
  source?: string;
  /** Label hiển thị cho source link (mặc định: domain hoặc "Nguồn") */
  sourceLabel?: string;
  /** CSS max-width (mặc định '100%') */
  width?: string;
  /** Thêm border quanh ảnh — hữu ích cho screenshot nền trắng trên dark theme */
  bordered?: boolean;
}

const {
  src,
  alt,
  caption,
  source,
  sourceLabel,
  width = '100%',
  bordered = false,
} = Astro.props;

let autoLabel = sourceLabel;
if (!autoLabel && source) {
  try {
    autoLabel = new URL(source).hostname.replace(/^www\./, '');
  } catch {
    autoLabel = 'Nguồn';
  }
}
---

<figure
  class={`report-image${bordered ? ' report-image--bordered' : ''}`}
  style={`max-width: ${width};`}
>
  <img
    src={src}
    alt={alt}
    loading="lazy"
    decoding="async"
    data-lightbox
    title="Click để phóng to"
    style="cursor: zoom-in;"
  />
  {(caption || source) && (
    <figcaption>
      {caption && <span class="caption-text" set:html={caption} />}
      {source && (
        <a class="caption-source" href={source} target="_blank" rel="noopener noreferrer">
          ↗ {autoLabel}
        </a>
      )}
    </figcaption>
  )}
</figure>

<script>
  // Lightbox — singleton overlay, shared across all ReportImage instances
  (function () {
    if (document.getElementById('ri-lightbox')) return;

    const overlay = document.createElement('div');
    overlay.id = 'ri-lightbox';
    overlay.innerHTML = `
      <div class="ri-lb-backdrop"></div>
      <div class="ri-lb-content">
        <button class="ri-lb-close" aria-label="Đóng">✕</button>
        <img class="ri-lb-img" src="" alt="" />
        <p class="ri-lb-caption"></p>
      </div>
    `;
    document.body.appendChild(overlay);

    const lbImg = overlay.querySelector<HTMLImageElement>('.ri-lb-img')!;
    const lbCaption = overlay.querySelector<HTMLParagraphElement>('.ri-lb-caption')!;

    function open(img: HTMLImageElement) {
      lbImg.src = img.src;
      lbImg.alt = img.alt;
      const fig = img.closest('figure');
      const captionEl = fig?.querySelector('.caption-text');
      lbCaption.textContent = captionEl?.textContent ?? img.alt;
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      overlay.classList.remove('open');
      document.body.style.overflow = '';
      lbImg.src = '';
    }

    overlay.querySelector('.ri-lb-backdrop')!.addEventListener('click', close);
    overlay.querySelector('.ri-lb-close')!.addEventListener('click', close);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });

    document.querySelectorAll<HTMLImageElement>('img[data-lightbox]').forEach(img => {
      img.addEventListener('click', () => open(img));
    });
  })();
</script>

<style>
  .report-image {
    margin: 20px 0 28px;
    display: block;
  }

  .report-image img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
    background: var(--bg-elev);
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .report-image img:hover {
    opacity: 0.9;
    transform: scale(1.005);
  }

  .report-image--bordered img {
    border: 1px solid var(--border);
    box-shadow: 0 2px 12px color-mix(in srgb, var(--bg) 60%, transparent);
  }

  figcaption {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-top: 8px;
    font-size: 12.5px;
    color: var(--text-muted);
    line-height: 1.5;
    flex-wrap: wrap;
  }

  .caption-text { flex: 1; min-width: 0; }

  .caption-source {
    flex-shrink: 0;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
    font-size: 11.5px;
    opacity: 0.85;
    transition: opacity 0.12s ease;
  }
  .caption-source:hover { opacity: 1; text-decoration: underline; }
</style>

<style is:global>
  #ri-lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9000;
    align-items: center;
    justify-content: center;
  }
  #ri-lightbox.open { display: flex; }

  .ri-lb-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .ri-lb-content {
    position: relative;
    z-index: 1;
    max-width: 92vw;
    max-height: 92vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .ri-lb-img {
    max-width: 100%;
    max-height: 82vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0,0,0,0.6);
  }

  .ri-lb-caption {
    color: rgba(255,255,255,0.7);
    font-size: 13px;
    text-align: center;
    max-width: 640px;
    margin: 0;
  }

  .ri-lb-close {
    position: absolute;
    top: -44px;
    right: 0;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    font-size: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .ri-lb-close:hover { background: rgba(255,255,255,0.2); }
</style>
