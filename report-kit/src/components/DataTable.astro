---
// DataTable.astro — bảng dữ liệu đơn giản (header + body)
interface Props {
  headers: string[];
  rows: string[][];
  /** class="compare" cho bảng so sánh nhiều cột */
  variant?: 'default' | 'compare';
  /** true: mỗi cell render bằng set:html (vd <code> trong ô) */
  richCells?: boolean;
}

const { headers, rows, variant = 'default', richCells = false } = Astro.props;
const cls = variant === 'compare' ? 'compare' : undefined;
---
<table class={cls}>
  <thead>
    <tr>
      {headers.map((h) => (
        <th>{h}</th>
      ))}
    </tr>
  </thead>
  <tbody>
    {rows.map((row) => (
      <tr>
        {row.map((cell) =>
          richCells ? <td set:html={cell} /> : <td>{cell}</td>
        )}
      </tr>
    ))}
  </tbody>
</table>
