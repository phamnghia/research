---
/**
 * Link dạng nút tới trang phân tích sâu (technique deep-dive).
 * Highlight nhẹ: viền nét đứt + halo gradient (accent → purple → cyan).
 */
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<p class="deep-dive-wrap">
  <a class="deep-dive-link" href={href}>
    <span class="deep-dive-arrow" aria-hidden="true">→</span>
    <span class="deep-dive-text"><slot /></span>
  </a>
</p>

<style>
  .deep-dive-wrap {
    position: relative;
    margin: 14px 0 4px;
  }

  .deep-dive-link {
    position: relative;
    display: inline-flex;
    align-items: flex-start;
    gap: 0.45em;
    max-width: 100%;
    padding: 10px 16px 10px 14px;
    border-radius: 10px;
    text-decoration: none;
    font-size: 14px;
    line-height: 1.45;
    color: var(--accent);
    background: color-mix(in srgb, var(--bg-elev) 92%, var(--accent) 8%);
    border: 2px dashed color-mix(in srgb, var(--accent) 55%, var(--border));
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--accent) 12%, transparent),
      0 4px 18px color-mix(in srgb, var(--accent) 14%, transparent);
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease,
      box-shadow 0.15s ease;
  }

  .deep-dive-link::before {
    content: "";
    position: absolute;
    inset: -4px;
    z-index: -1;
    border-radius: 13px;
    background: linear-gradient(
      125deg,
      var(--accent),
      var(--purple) 45%,
      var(--cyan)
    );
    opacity: 0.38;
    filter: blur(8px);
    pointer-events: none;
    transition: opacity 0.15s ease;
  }

  .deep-dive-link:hover {
    color: var(--text-bright);
    background: color-mix(in srgb, var(--bg-elev) 85%, var(--accent) 15%);
    border-color: color-mix(in srgb, var(--accent) 75%, var(--purple));
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--accent) 22%, transparent),
      0 6px 22px color-mix(in srgb, var(--accent) 22%, transparent);
  }

  .deep-dive-link:hover::before {
    opacity: 0.52;
  }

  .deep-dive-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .deep-dive-arrow {
    flex-shrink: 0;
    margin-top: 0.12em;
    font-weight: 600;
  }

  .deep-dive-text {
    min-width: 0;
    text-wrap: balance;
  }
</style>
