---
import { Icon } from 'astro-icon/components';
// Sidebar.astro — sidebar mục lục cho một báo cáo
// Nhận groups = [{ title: "...", items: [{ href, label, section? }] }]
export interface SidebarItem {
  href: string;
  label: string;
  /** true = đậm, được dùng cho header section (intro, conclusion...) */
  section?: boolean;
}
export interface SidebarGroup {
  title: string;
  items: SidebarItem[];
}

interface Props {
  groups: SidebarGroup[];
  intro?: string;
}

const { groups, intro = 'Mục lục' } = Astro.props;
---

<div class="sidebar-column">
  <button
    type="button"
    class="sidebar-menu-btn"
    aria-label="Mở hoặc đóng mục lục"
    aria-controls="report-sidebar"
    aria-expanded="false"
  >
    <Icon name="lucide:menu" class="sidebar-menu-btn__icon" aria-hidden="true" />
  </button>
  <div class="sidebar-backdrop" aria-hidden="true"></div>
  <aside class="report-sidebar" id="report-sidebar">
    <a class="report-sidebar-brand" href="/">
      <img
        src="/devalaxy.png"
        alt="DEVALAXY"
        width="220"
        height="48"
        class="report-sidebar-brand__img"
        decoding="async"
      />
    </a>
    <div class="toc-intro">{intro}</div>
    {groups.map((group) => (
      <>
        <h3>{group.title}</h3>
        <ul>
          {group.items.map((item) => (
            <li>
              <a href={item.href} class={item.section ? 'section' : ''} set:html={item.label} />
            </li>
          ))}
        </ul>
      </>
    ))}
  </aside>
  <header class="report-mobile-topbar" aria-label="DEVALAXY">
    <a class="report-mobile-topbar__brand" href="/">
      <img
        src="/devalaxy.png"
        alt="DEVALAXY"
        width="220"
        height="48"
        class="report-mobile-topbar__img"
        decoding="async"
      />
    </a>
  </header>
</div>

<script>
  import { initReportSidebarToggle } from '../lib/reportSidebarToggle.ts';
  initReportSidebarToggle();
</script>
