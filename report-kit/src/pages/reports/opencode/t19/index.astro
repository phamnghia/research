      <Hero
        title="T19 — Sub-agent delegation via Task tool"
        subtitle="Parent agent spawn child session qua Task tool — agent con làm search/explore/plan với <strong>clean context riêng</strong>, trả lại compact summary. Parent không bị ô nhiễm bởi tool output của sub-task."
        meta={[
          { label: 'Nhóm',  value: 'C — Tool Design' },
          { label: 'File',  value: '<code>tool/task.ts</code> · Lines 69–145' },
