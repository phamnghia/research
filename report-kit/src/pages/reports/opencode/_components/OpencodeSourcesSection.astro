    title="Repo gốc & docs"
    items={[
      '<a href="https://github.com/anomalyco/opencode">anomalyco/opencode — GitHub</a>',
      '<a href="https://opencode.ai/">OpenCode — Official site</a>',
      '<a href="https://opencode.ai/docs/agents/">OpenCode Agents docs</a>',
      '<a href="https://opencode.ai/docs/permissions/">OpenCode Permissions docs</a>',
    ]}
  />
