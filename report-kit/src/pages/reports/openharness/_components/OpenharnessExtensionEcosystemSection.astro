      model."""</span> fields = {} <span class="kw">for</span> prop, spec <span
      class="kw">in</span> schema.get(<span class="str">"properties"</span>,
      {}).items(): py_type = _json_type_to_python(spec.get(<span
      class="str">"type"</span>, <span class="str">"string"</span>))
      fields[prop] = (py_type, ...) <span class="com"># required</span> <span
      class="kw">return</span> create_model(<span class="fn">f</span><span
      class="str">"Mcp_{name}_Input"</span>, **fields)</code></pre> <div
      class="why"><strong>Tại sao quan trọng:</strong> MCP cho phép OpenHarness
      dùng tool từ nhiều server độc lập (GitHub, Jira, Slack MCPs...).
      <code>AsyncExitStack</code> per-server đảm bảo cleanup đúng ngay cả khi
      một server fail init. <code>create_model</code> build Pydantic từ JSON
      schema runtime — tức tool được validate như tool native. Namespace
      <code>mcp__&lt;server&gt;__&lt;tool&gt;</code> tránh conflict giữa server
      có cùng tool name. Dual transport stdio+HTTP cho local subprocess hoặc
      remote SaaS MCP.</div> <h4>Code example (generic)</h4> <pre><code><span
      class="kw">from</span> contextlib <span class="kw">import</span>
      AsyncExitStack <span class="kw">from</span> pydantic <span
      class="kw">import</span> create_model <span class="kw">class</span> <span
      class="type">McpManager</span>: <span class="kw">async def</span> <span
      class="fn">__aenter__</span>(self): self.stack = <span
      class="kw">await</span> AsyncExitStack().__aenter__() self.sessions = {}
      self.tools = [] <span class="kw">for</span> name, cfg <span
      class="kw">in</span> self.configs.items(): ctx = stdio_client(cfg) <span
      class="kw">if</span> cfg.transport == <span class="str">"stdio"</span>
      <span class="kw">else</span> sse_client(cfg) streams = <span
      class="kw">await</span> self.stack.enter_async_context(ctx) sess = <span
      class="kw">await</span>
      self.stack.enter_async_context(ClientSession(*streams)) <span
      class="kw">await</span> sess.initialize() <span class="kw">for</span> t
      <span class="kw">in</span> (<span class="kw">await</span>
      sess.list_tools()).tools: self.tools.append({<span
      class="str">"name"</span>: <span class="fn">f</span><span
      class="str">"mcp__{name}__{t.name}"</span>, <span
      class="str">"model"</span>: create_model(<span class="fn">f</span><span
      class="str">"M_{t.name}"</span>, **...)}) <span class="kw">return</span>
      self</code></pre>
    </Fragment>
    <ProsCons
      pros={[
        "Dual transport — stdio (local) + HTTP (remote)",
        "AsyncExitStack → nested cleanup an toàn",
        "Dynamic Pydantic — tool MCP validate như native",
        "Namespace tránh conflict",
      ]}
      cons={[
        "JSON schema → Pydantic chưa hỗ trợ allOf/oneOf phức tạp",
        "Một server stuck block toàn bộ init (không có per-server timeout)",
        "SSE transport không có retry built-in",
        "Schema không support descriptions for enum values",
      ]}
    />
