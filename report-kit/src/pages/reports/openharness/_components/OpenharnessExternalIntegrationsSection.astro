  <Technique
    id={"t30"}
    title={"T30. Cron scheduler + persistent background tasks"}
    tid={"G.4"}
    location={"<strong>File:</strong> <code>src/openharness/tasks/manager.py</code> · <code>src/openharness/services/cron_scheduler.py</code> · <strong>Storage:</strong> <code>~/.openharness/cron/registry.json</code> + <code>cron_history.jsonl</code> · <strong>Tick:</strong> 30s"}
  >
    <Fragment is:raw>
      <h4>Code từ OpenHarness</h4> <pre><code><span class="kw">import</span>
      asyncio, json <span class="kw">from</span> datetime <span
      class="kw">import</span> datetime <span class="kw">from</span> croniter
      <span class="kw">import</span> croniter <span
      class="deco">@dataclass</span> <span class="kw">class</span> <span
      class="type">CronJob</span>: job_id: str name: str cron_expr: str <span
      class="com"># "*/30 * * * *"</span> prompt: str <span class="com"># agent
      prompt khi fire</span> enabled: bool = <span class="kw">True</span>
      last_run: str | <span class="kw">None</span> = <span
      class="kw">None</span> next_run: str | <span class="kw">None</span> =
      <span class="kw">None</span> <span class="kw">class</span> <span
      class="type">CronScheduler</span>: TICK = 30 <span class="com">#
      seconds</span> <span class="kw">def</span> <span
      class="fn">__init__</span>(self, registry_path: Path, history_path: Path):
      self.registry_path = registry_path self.history_path = history_path
      self.jobs: dict[str, CronJob] = self._load() <span class="kw">def</span>
      <span class="fn">_load</span>(self) -&gt; dict[str, CronJob]: <span
      class="kw">if</span> <span class="kw">not</span>
      self.registry_path.exists(): <span class="kw">return</span> {} data =
      json.loads(self.registry_path.read_text()) <span class="kw">return</span>
      {j[<span class="str">"job_id"</span>]: CronJob(**j) <span
      class="kw">for</span> j <span class="kw">in</span> data} <span
      class="kw">def</span> <span class="fn">_save</span>(self):
      self.registry_path.write_text(json.dumps( [asdict(j) <span
      class="kw">for</span> j <span class="kw">in</span> self.jobs.values()],
      indent=2, )) <span class="kw">async def</span> <span
      class="fn">run_forever</span>(self, on_fire: Callable[[CronJob],
      Awaitable]): <span class="kw">while</span> <span class="kw">True</span>:
      now = datetime.utcnow() <span class="kw">for</span> job <span
      class="kw">in</span> list(self.jobs.values()): <span class="kw">if</span>
      <span class="kw">not</span> job.enabled: <span class="kw">continue</span>
      base = datetime.fromisoformat(job.last_run) <span class="kw">if</span>
      job.last_run <span class="kw">else</span> now itr =
      croniter(job.cron_expr, base) <span class="kw">if</span>
      itr.get_next(datetime) &lt;= now: asyncio.create_task(self._fire(job,
      on_fire)) job.last_run = now.isoformat() self._save() <span
      class="kw">await</span> asyncio.sleep(self.TICK) <span class="kw">async
      def</span> <span class="fn">_fire</span>(self, job: CronJob, on_fire):
      <span class="kw">try</span>: result = <span class="kw">await</span>
      on_fire(job) self._append_history({<span class="str">"job_id"</span>:
      job.job_id, <span class="str">"fired_at"</span>:
      datetime.utcnow().isoformat(), <span class="str">"ok"</span>: <span
      class="kw">True</span>, <span class="str">"result_preview"</span>:
      result[:500]}) <span class="kw">except</span> Exception <span
      class="kw">as</span> e: self._append_history({<span
      class="str">"job_id"</span>: job.job_id, <span class="str">"ok"</span>:
      <span class="kw">False</span>, <span class="str">"error"</span>: str(e)})
      <span class="kw">def</span> <span class="fn">_append_history</span>(self,
      entry: dict): <span class="kw">with</span> self.history_path.open(<span
      class="str">"a"</span>) <span class="kw">as</span> f:
      f.write(json.dumps(entry) + <span class="str">"\n"</span>) </code></pre>
      <div class="why"><strong>Tại sao quan trọng:</strong> Biến agent từ
      "on-demand" thành "proactive". User có thể set: "mỗi sáng 8h, check CI
      main branch xong ping Slack nếu fail", "mỗi 30 phút, pull Jira rồi update
      status". <strong>Persistent</strong> (JSON registry) → sống qua restart.
      <strong>History log JSONL</strong> → audit. <strong>Per-job
      enable/disable</strong> → maintenance dễ. <strong>Tick 30s</strong> là
      trade-off: đủ nhanh để không miss 1-phút-cron, đủ chậm để không spam.
      Croniter lib xử lý edge case (cuối tháng, DST).</div> <h4>Code example
      (generic)</h4> <pre><code><span class="kw">import</span> asyncio <span
      class="kw">from</span> apscheduler.schedulers.asyncio <span
      class="kw">import</span> AsyncIOScheduler <span class="kw">from</span>
      apscheduler.triggers.cron <span class="kw">import</span> CronTrigger <span
      class="kw">async def</span> <span class="fn">agent_job</span>(prompt:
      str): response = <span class="kw">await</span> run_agent(prompt)
      save_history(prompt, response) <span class="kw">async def</span> <span
      class="fn">main</span>(): scheduler = AsyncIOScheduler() <span
      class="com"># Cron: Mon-Fri 09:00</span> scheduler.add_job( agent_job,
      trigger=CronTrigger.from_crontab(<span class="str">"0 9 * * 1-5"</span>),
      args=[<span class="str">"Summarize overnight alerts"</span>], id=<span
      class="str">"daily-triage"</span>, replace_existing=<span
      class="kw">True</span>, ) scheduler.start() <span class="kw">await</span>
      asyncio.Event().wait() <span class="com"># run forever</span>
      </code></pre>
    </Fragment>
    <ProsCons
      pros={[
        "Agent thành proactive assistant — không cần user ping",
        "Persist qua restart → reliability",
        "History log cho audit + debug",
        "Per-job enable/disable dễ pause khi maintenance",
      ]}
      cons={[
        "Tick 30s miss cron &lt;30s granularity",
        "Không distributed — nhiều instance chạy sẽ duplicate fire",
        "JSON registry không concurrent-safe (write qua rename cần thêm)",
        "Failure recovery phụ thuộc user đọc history — không có alert auto",
      ]}
    />
