      items={[
        '<a href="https://slack.dev/bolt-python/">Slack Bolt Python SDK</a>',
        '<a href="https://open.feishu.cn/document/home">Feishu OAPI (lark-oapi)</a>',
        '<a href="https://docs.python-telegram-bot.org/">python-telegram-bot docs</a>',
      ]}
    />
