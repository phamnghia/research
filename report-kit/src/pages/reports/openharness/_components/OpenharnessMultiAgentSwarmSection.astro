  <Technique
    id={"t25"}
    title={"T25. Git worktree isolation per agent"}
    tid={"F.4"}
    location={"<strong>File:</strong> <code>src/openharness/swarm/worktree.py</code> · <strong>Lines:</strong> 1–80 · <strong>Slug:</strong> max 64 chars, <code>[a-zA-Z0-9._-]</code>"}
  >
    <Fragment is:raw>
      <h4>Code từ OpenHarness</h4> <pre><code><span class="kw">import</span>
      asyncio, re <span class="kw">from</span> pathlib <span
      class="kw">import</span> Path SLUG_RE = re.compile(<span
      class="fn">r</span><span class="str">"^[a-zA-Z0-9._-]+$"</span>)
      MAX_SLUG_LEN = <span class="num">64</span> <span class="kw">def</span>
      <span class="fn">validate_slug</span>(slug: str) -&gt; str: <span
      class="str">"""Reject .., absolute paths, and control chars."""</span>
      <span class="kw">if not</span> slug <span class="kw">or</span> len(slug)
      &gt; MAX_SLUG_LEN: <span class="kw">raise</span> ValueError(<span
      class="fn">f</span><span class="str">"slug length must be
      1..{MAX_SLUG_LEN}"</span>) <span class="kw">if not</span>
      SLUG_RE.match(slug): <span class="kw">raise</span> ValueError(<span
      class="fn">f</span><span class="str">"invalid slug: {slug!r}"</span>)
      <span class="kw">if</span> <span class="str">".."</span> <span
      class="kw">in</span> slug <span class="kw">or</span>
      slug.startswith((<span class="str">"/"</span>, <span
      class="str">"-"</span>)): <span class="kw">raise</span> ValueError(<span
      class="fn">f</span><span class="str">"slug must not traverse or start with
      /-: {slug!r}"</span>) <span class="kw">return</span> slug <span
      class="kw">async def</span> <span
      class="fn">create_worktree</span>(repo_root: Path, slug: str, *, base_ref:
      str = <span class="str">"HEAD"</span>) -&gt; Path: <span
      class="str">"""Create a shallow worktree for subagent isolation."""</span>
      slug = validate_slug(slug) worktree_path = repo_root / <span
      class="str">".openharness"</span> / <span class="str">"worktrees"</span> /
      slug branch = <span class="fn">f</span><span
      class="str">"openharness/swarm/{slug}"</span> <span class="com"># Reuse
      existing worktree if slug already exists</span> <span class="kw">if</span>
      worktree_path.exists(): <span class="kw">return</span> worktree_path
      worktree_path.parent.mkdir(parents=<span class="kw">True</span>,
      exist_ok=<span class="kw">True</span>) cmd = [<span
      class="str">"git"</span>, <span class="str">"-C"</span>, <span
      class="kw">str</span>(repo_root), <span class="str">"worktree"</span>,
      <span class="str">"add"</span>, <span class="str">"--quiet"</span>, <span
      class="str">"-b"</span>, branch, <span
      class="kw">str</span>(worktree_path), base_ref] proc = <span
      class="kw">await</span> asyncio.create_subprocess_exec( *cmd,
      stdout=asyncio.subprocess.PIPE, stderr=asyncio.subprocess.PIPE, ) _,
      stderr = <span class="kw">await</span> proc.communicate() <span
      class="kw">if</span> proc.returncode != <span class="num">0</span>: <span
      class="kw">raise</span> RuntimeError(<span class="fn">f</span><span
      class="str">"git worktree add failed: {stderr.decode()}"</span>) <span
      class="kw">return</span> worktree_path <span class="kw">async def</span>
      <span class="fn">remove_worktree</span>(repo_root: Path, slug: str, *,
      force: bool = <span class="kw">False</span>): <span class="str">"""Remove
      a worktree; orphan branch left as cleanup-later."""</span> slug =
      validate_slug(slug) worktree_path = repo_root / <span
      class="str">".openharness"</span> / <span class="str">"worktrees"</span> /
      slug args = [<span class="str">"git"</span>, <span
      class="str">"-C"</span>, <span class="kw">str</span>(repo_root), <span
      class="str">"worktree"</span>, <span class="str">"remove"</span>, <span
      class="kw">str</span>(worktree_path)] <span class="kw">if</span> force:
      args.append(<span class="str">"--force"</span>) ...</code></pre> <div
      class="why"><strong>Tại sao quan trọng:</strong> Hai agent cùng sửa file
      repo → merge conflict / race condition. Worktree cho phép mỗi agent chạy
      trên <strong>branch riêng, checkout riêng</strong>, vẫn share
      <code>.git</code> object database (hiệu quả disk). Sau khi agent xong,
      merge branch về main. Slug validation ngăn path traversal
      (<code>..</code>) — quan trọng khi slug đến từ LLM input. Branch prefix
      <code>openharness/swarm/</code> để dễ cleanup và không va chạm với dev
      branch.</div> <h4>Code example (generic)</h4> <pre><code><span
      class="kw">import</span> asyncio, re <span class="kw">from</span> pathlib
      <span class="kw">import</span> Path SLUG_RE = re.compile(<span
      class="fn">r</span><span class="str">"^[a-zA-Z0-9._-]{1,64}$"</span>)
      <span class="kw">async def</span> <span
      class="fn">make_worktree</span>(repo: Path, slug: str, base=<span
      class="str">"HEAD"</span>) -&gt; Path: <span class="kw">if not</span>
      SLUG_RE.match(slug) <span class="kw">or</span> <span
      class="str">".."</span> <span class="kw">in</span> slug: <span
      class="kw">raise</span> ValueError(<span class="str">"bad slug"</span>) wt
      = repo / <span class="str">".worktrees"</span> / slug <span
      class="kw">if</span> wt.exists(): <span class="kw">return</span> wt branch
      = <span class="fn">f</span><span class="str">"agent/{slug}"</span> proc =
      <span class="kw">await</span> asyncio.create_subprocess_exec( <span
      class="str">"git"</span>, <span class="str">"-C"</span>, <span
      class="kw">str</span>(repo), <span class="str">"worktree"</span>, <span
      class="str">"add"</span>, <span class="str">"-b"</span>, branch, <span
      class="kw">str</span>(wt), base, stdout=asyncio.subprocess.DEVNULL,
      stderr=asyncio.subprocess.PIPE, ) _, err = <span class="kw">await</span>
      proc.communicate() <span class="kw">if</span> proc.returncode != <span
      class="num">0</span>: <span class="kw">raise</span>
      RuntimeError(err.decode()) <span class="kw">return</span> wt</code></pre>
    </Fragment>
    <ProsCons
      pros={[
        "True file isolation — mỗi agent có riêng checkout",
        "Share .git objects → disk efficient",
        "Mỗi branch experiment độc lập",
        "Slug validation tránh path traversal",
      ]}
      cons={[
        "Git worktree overhead ~100-500ms mỗi spawn",
        "Cleanup thủ công khi agent crash → orphan branch",
        "Không work với submodule + LFS clean",
        "Disk space nhân lên khi working tree lớn",
