        '<a href="https://github.com/openai/swarm">OpenAI Swarm — Research framework</a>',
        '<a href="https://dev.to/aws/build-multi-agent-systems-using-the-agents-as-tools-pattern-jce">DEV — Agents as Tools Pattern (comparison)</a>',
      ]}
    />
