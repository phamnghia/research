---
// /components — Showcase page demonstrating every UI kit component.
// Mở http://127.0.0.1:4321/components/ khi chạy `npm run dev`.
import IndexLayout from '../layouts/IndexLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Hero from '../components/Hero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Section from '../components/Section.astro';
import Subheading from '../components/Subheading.astro';
import Technique from '../components/Technique.astro';
import ProsCons from '../components/ProsCons.astro';
import Callout from '../components/Callout.astro';
import Chip from '../components/Chip.astro';
import Diagram from '../components/Diagram.astro';
import CodeBlock from '../components/CodeBlock.astro';
import RefList from '../components/RefList.astro';
import SummaryTable from '../components/SummaryTable.astro';
import DataTable from '../components/DataTable.astro';
import LinkList from '../components/LinkList.astro';
import WhyImportant from '../components/WhyImportant.astro';
import DeepDiveLink from '../components/DeepDiveLink.astro';
---
<IndexLayout
  title="Components — Research Report Kit"
  description="Showcase mọi component của Research Report Kit, kèm ví dụ render thực và code snippet."
>
  <header class="index-hero">
    <h1>Components showcase</h1>
    <div class="sub">
      Toàn bộ component của report-kit, render sống + code snippet. Dùng trang này khi muốn
      xem nhanh component nào làm gì trước khi viết báo cáo mới. File template đầy đủ
      xem ở <code>src/pages/reports/_template.astro</code>.
    </div>
  </header>

  <nav class="components-toc">
    <strong>Nhảy tới:</strong>
    <a href="#layouts">Layouts</a> ·
    <a href="#breadcrumb">Breadcrumb</a> ·
    <a href="#sidebar">Sidebar</a> ·
    <a href="#hero">Hero</a> ·
    <a href="#section">Section</a> ·
    <a href="#subheading">Subheading</a> ·
    <a href="#technique">Technique</a> ·
    <a href="#whyimportant">WhyImportant</a> ·
    <a href="#proscons">ProsCons</a> ·
    <a href="#callout">Callout</a> ·
    <a href="#chip">Chip</a> ·
    <a href="#diagram">Diagram</a> ·
    <a href="#codeblock">CodeBlock</a> ·
    <a href="#deepdivelink">DeepDiveLink</a> ·
    <a href="#reflist">RefList</a> ·
    <a href="#linklist">LinkList</a> ·
    <a href="#summarytable">SummaryTable</a> ·
    <a href="#datatable">DataTable</a>
  </nav>

  {/* ─────── Layouts ─────── */}
  <section class="showcase-section" id="layouts">
    <h2>Layouts</h2>
    <p>
      <code>ReportLayout</code> wrap mỗi báo cáo — inject <code>report.css</code>,
      set <code>&lt;title&gt;</code>. Page tự define <code>&lt;div class="layout"&gt;</code>.
      <code>IndexLayout</code> dành cho trang landing & showcase.
    </p>
    <pre class="example-code"><code>{`import ReportLayout from '../../layouts/ReportLayout.astro';

<ReportLayout title="Tên báo cáo" description="Mô tả ngắn">
  <div class="layout">
    <Sidebar ... />
    <main> ... </main>
  </div>
</ReportLayout>`}</code></pre>
  </section>

  {/* ─────── Breadcrumb ─────── */}
  <section class="showcase-section" id="breadcrumb">
    <h2>Breadcrumb</h2>
    <div class="example-render">
      <Breadcrumb />
    </div>
    <pre class="example-code"><code>{`<Breadcrumb />
<Breadcrumb href="/" label="Tất cả báo cáo" />`}</code></pre>
  </section>

  {/* ─────── Sidebar ─────── */}
  <section class="showcase-section" id="sidebar">
    <h2>Sidebar</h2>
    <p>
      Cột mục lục cố định bên trái. Prop <code>groups</code> là mảng các group,
      mỗi group có <code>items: {`[{ href, label, section? }]`}</code>.
      Khi <code>section: true</code>, item được in đậm như heading.
    </p>
    <div class="example-render sidebar-demo">
      <Sidebar
        intro="Mục lục demo"
        groups={[
          { title: 'Mở đầu', items: [{ href: '#intro', label: 'Tổng quan', section: true }] },
          {
            title: 'Nhóm A',
            items: [
              { href: '#t1', label: '1. Kỹ thuật X' },
              { href: '#t2', label: '2. Kỹ thuật Y' },
            ],
          },
        ]}
      />
    </div>
    <pre class="example-code"><code>{`<Sidebar
  intro="Mục lục"
  groups={[
    { title: 'Mở đầu', items: [{ href: '#intro', label: 'Tổng quan', section: true }] },
    { title: 'Nhóm A', items: [
        { href: '#t1', label: '1. Kỹ thuật X' },
    ] },
  ]}
/>`}</code></pre>
  </section>

  {/* ─────── Hero ─────── */}
  <section class="showcase-section" id="hero">
    <h2>Hero</h2>
    <div class="example-render">
      <Hero
        title="Demo Hero"
        subtitle="Subtitle có thể chứa <a href='#'>link</a> và <code>inline code</code>."
        meta={[
          { label: 'Ngày', value: '2026-04-20' },
          { label: 'Repo', value: '<code>org/repo</code>' },
        ]}
      />
    </div>
    <pre class="example-code"><code>{`<Hero
  title="Tên report"
  subtitle="Mô tả ngắn, có thể chứa <a> và <code>"
  meta={[
    { label: 'Ngày', value: '2026-04-20' },
    { label: 'Repo', value: '<code>org/repo</code>' },
  ]}
/>`}</code></pre>
  </section>

  {/* ─────── Section ─────── */}
  <section class="showcase-section" id="section">
    <h2>Section</h2>
    <div class="example-render">
      <Section id="demo-sec" title="Một section h2" themeTag="Demo">
        <p>Body section. Có thể chứa bất cứ component nào bên trong.</p>
      </Section>
    </div>
    <pre class="example-code"><code>{`<Section id="intro" title="Tổng quan" themeTag="Intro">
  <p>...</p>
</Section>`}</code></pre>
  </section>

  {/* ─────── Subheading ─────── */}
  <section class="showcase-section" id="subheading">
    <h2>Subheading</h2>
    <div class="example-render">
      <Subheading level="h3" text="h3 Subheading" />
      <Subheading level="h4" text="h4 Subheading" />
    </div>
    <pre class="example-code"><code>{`<Subheading level="h3" text="Cách hoạt động" />
<Subheading level="h4" text="Chi tiết implementation" id="detail" />`}</code></pre>
  </section>

  {/* ─────── Technique ─────── */}
  <section class="showcase-section" id="technique">
    <h2>Technique</h2>
    <div class="example-render">
      <Technique
        id="demo-t1"
        title="Kỹ thuật demo"
        tid="A.1"
        location='File: <code>src/agent/loop.ts:1-42</code>'
      >
        <p>Nội dung technique. Thường chứa WhyImportant + code + ProsCons + RefList.</p>
      </Technique>
    </div>
    <pre class="example-code"><code>{`<Technique
  id="t1"
  title="1. Kỹ thuật X"
  tid="A.1"
  location='File: <code>src/agent/loop.ts:120-180</code>'
>
  <WhyImportant>...</WhyImportant>
  <CodeBlock>...</CodeBlock>
  <ProsCons pros={[...]} cons={[...]} />
  <RefList items={[...]} />
</Technique>`}</code></pre>
  </section>

  {/* ─────── WhyImportant ─────── */}
  <section class="showcase-section" id="whyimportant">
    <h2>WhyImportant</h2>
    <div class="example-render">
      <WhyImportant>
        <strong>Tại sao quan trọng.</strong> Giải thích rationale 2-3 câu.
      </WhyImportant>
    </div>
    <pre class="example-code"><code>{`<WhyImportant>
  <strong>Tại sao quan trọng.</strong> Giải thích 2-3 câu.
</WhyImportant>`}</code></pre>
  </section>

  {/* ─────── ProsCons ─────── */}
  <section class="showcase-section" id="proscons">
    <h2>ProsCons</h2>
    <div class="example-render">
      <ProsCons
        pros={[
          'Ưu điểm 1',
          'Ưu điểm 2 có <code>inline code</code>',
        ]}
        cons={[
          'Nhược 1',
          'Nhược 2 với <a href="#">link</a>',
        ]}
      />
    </div>
    <pre class="example-code"><code>{`<ProsCons
  pros={['Ưu 1', 'Ưu 2 có <code>inline</code>']}
  cons={['Nhược 1', 'Nhược 2 với <a href="#">link</a>']}
/>`}</code></pre>
  </section>

  {/* ─────── Callout ─────── */}
  <section class="showcase-section" id="callout">
    <h2>Callout</h2>
    <div class="example-render">
      <Callout type="info"><strong>Info</strong> — ghi chú thường.</Callout>
      <Callout type="warn"><strong>Warn</strong> — lưu ý / pitfall.</Callout>
      <Callout type="unique"><strong>Unique</strong> — điểm khác biệt.</Callout>
      <Callout type="success"><strong>Success</strong> — kết luận tích cực.</Callout>
    </div>
    <pre class="example-code"><code>{`<Callout type="info">...</Callout>
<Callout type="warn">...</Callout>
<Callout type="unique">...</Callout>
<Callout type="success">...</Callout>`}</code></pre>
  </section>

  {/* ─────── Chip ─────── */}
  <section class="showcase-section" id="chip">
    <h2>Chip</h2>
    <div class="example-render">
      <Chip>default</Chip>{' '}
      <Chip variant="green">green</Chip>{' '}
      <Chip variant="amber">amber</Chip>{' '}
      <Chip variant="purple">purple</Chip>{' '}
      <Chip variant="cyan">cyan</Chip>{' '}
      <Chip variant="red">red</Chip>{' '}
      <Chip variant="unique">unique</Chip>
    </div>
    <pre class="example-code"><code>{`<Chip>default</Chip>
<Chip variant="green">Loop</Chip>
<Chip variant="unique">UNIQUE</Chip>`}</code></pre>
  </section>

  {/* ─────── Diagram ─────── */}
  <section class="showcase-section" id="diagram">
    <h2>Diagram</h2>
    <div class="example-render">
      <Diagram>{`
┌──────────┐     ┌──────────┐
│  Model   │ ──▶ │  Tool    │
└──────────┘     └──────────┘
      ▲                │
      └────── result ◀─┘
`}</Diagram>
    </div>
    <pre class="example-code"><code>{`<Diagram>{\`
┌──────────┐     ┌──────────┐
│  Model   │ ──▶ │  Tool    │
└──────────┘     └──────────┘
\`}</Diagram>`}</code></pre>
  </section>

  {/* ─────── CodeBlock ─────── */}
  <section class="showcase-section" id="codeblock">
    <h2>CodeBlock</h2>
    <div class="example-render">
      <CodeBlock caption="caption.ts">
        <Fragment is:raw>{`function hi(name) {
  return "hi " + name;
}`}</Fragment>
      </CodeBlock>
    </div>
    <p class="tip">
      <strong>Tip:</strong> highlight bằng <a href="https://shiki.style/">Shiki</a> (github-light /
      github-dark, theo <code>prefers-color-scheme</code>). Khi code có <code>{'{'}</code>/
      <code>{'}'}</code>, bọc slot bằng{" "}
      <code>{'<Fragment is:raw>{`...`}</Fragment>'}</code>.
      Prop tuỳ chọn <code>lang</code> (vd <code>typescript</code>, <code>bash</code>, <code>markdown</code>);
      không truyền thì component suy luận. Chuỗi HTML span cũ (<code>.kw</code>…) vẫn được strip và
      highlight lại.
    </p>
    <pre class="example-code"><code>{`<CodeBlock caption="loop.ts" lang="typescript">
  <Fragment is:raw>{\`async function runLoop() { ... }\`}</Fragment>
</CodeBlock>

<CodeBlock code="const x = 1;" lang="typescript" />`}</code></pre>
  </section>

  {/* ─────── DeepDiveLink ─────── */}
  <section class="showcase-section" id="deepdivelink">
    <h2>DeepDiveLink</h2>
    <p class="tip">
      Nút/link tới trang phân tích sâu từng technique (báo cáo opencode). Viền nét đứt + halo gradient
      nhẹ (accent → purple → cyan).
    </p>
    <div class="example-render">
      <DeepDiveLink href="/reports/opencode/t2/">
        Phân tích sâu T2: event types, Effect.Stream, UI real-time update, cancel semantics
      </DeepDiveLink>
    </div>
    <pre class="example-code"><code>{`<DeepDiveLink href="/reports/opencode/t2/">
  Phân tích sâu T2: …mô tả ngắn…
</DeepDiveLink>`}</code></pre>
  </section>

  {/* ─────── RefList ─────── */}
  <section class="showcase-section" id="reflist">
    <h2>RefList</h2>
    <div class="example-render">
      <RefList
        items={[
          '<a href="https://example.com/a">Bài A — Tác giả</a>',
          '<a href="https://example.com/b">Bài B — Tác giả khác</a>',
        ]}
      />
    </div>
    <pre class="example-code"><code>{`<RefList
  title="Tham khảo"
  items={[
    '<a href="https://...">Bài A — Tác giả</a>',
    '<a href="https://...">Bài B</a>',
  ]}
/>`}</code></pre>
  </section>

  {/* ─────── LinkList ─────── */}
  <section class="showcase-section" id="linklist">
    <h2>LinkList</h2>
    <div class="example-render">
      <LinkList
        title="Link đọc thêm"
        items={[
          '<a href="https://martinfowler.com/articles/harness-engineering.html">Martin Fowler — Harness Engineering</a>',
          '<a href="https://openai.com/index/harness-engineering/">OpenAI — Harness engineering</a>',
        ]}
      />
    </div>
    <pre class="example-code"><code>{`<LinkList
  title="Link đọc thêm"
  items={[
    '<a href="...">Link 1</a>',
    '<a href="...">Link 2</a>',
  ]}
/>`}</code></pre>
  </section>

  {/* ─────── SummaryTable ─────── */}
  <section class="showcase-section" id="summarytable">
    <h2>SummaryTable</h2>
    <div class="example-render">
      <SummaryTable
        rows={[
          { id: 'A.1', title: '<a href="#">Kỹ thuật X</a>', chipLabel: 'Loop', chipVariant: 'green' },
          { id: 'A.2', title: '<a href="#">Kỹ thuật Y</a>', chipLabel: 'Context', chipVariant: 'amber' },
          { id: 'B.1', title: '<a href="#">Kỹ thuật Z</a>', chipLabel: 'UNIQUE', chipVariant: 'unique' },
        ]}
      />
    </div>
    <pre class="example-code"><code>{`<SummaryTable
  headers={['ID', 'Kỹ thuật', 'Theme']}
  rows={[
    { id: 'A.1', title: '<a href="#t1">...</a>', chipLabel: 'Loop', chipVariant: 'green' },
  ]}
/>`}</code></pre>
  </section>

  {/* ─────── DataTable ─────── */}
  <section class="showcase-section" id="datatable">
    <h2>DataTable</h2>
    <div class="example-render">
      <DataTable
        variant="compare"
        richCells
        headers={['Aspect', 'Project A', 'Project B']}
        rows={[
          ['Language', '<code>TypeScript</code>', '<code>Python</code>'],
          ['Multi-agent', 'Task tool', '<strong>Subprocess swarm</strong>'],
        ]}
      />
    </div>
    <pre class="example-code"><code>{`<DataTable
  variant="compare"
  richCells
  headers={['Aspect', 'A', 'B']}
  rows={[
    ['Language', '<code>TS</code>', '<code>Python</code>'],
  ]}
/>`}</code></pre>
  </section>

  <footer class="index-footer">
    <p>
      <strong>Tiếp theo:</strong> copy <code>src/pages/reports/_template.astro</code> khi
      bắt đầu báo cáo mới. Xem <a href="/"><code>/</code></a> để thấy các báo cáo hiện có.
    </p>
  </footer>
</IndexLayout>

<style>
  .components-toc {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 18px;
    margin-bottom: 32px;
    font-size: 13.5px;
    color: var(--text-muted);
    line-height: 1.9;
  }
  .components-toc a {
    color: var(--accent);
    text-decoration: none;
  }
  .components-toc a:hover { text-decoration: underline; }

  .showcase-section {
    margin: 40px 0;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border-soft);
  }
  .showcase-section > h2 {
    margin: 0 0 12px;
    font-size: 22px;
    color: var(--text-bright);
    font-weight: 600;
  }
  .showcase-section > p {
    color: var(--text-muted);
    font-size: 14px;
    max-width: 820px;
  }

  .example-render {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px;
    margin: 16px 0;
  }
  .example-render > * + * { margin-top: 12px; }

  /* Constrain the sidebar demo so it doesn't try to be 280px fixed */
  .sidebar-demo {
    display: grid;
    grid-template-columns: 260px 1fr;
    align-items: start;
  }
  .sidebar-demo aside {
    position: static !important;
    height: auto !important;
    border-right: 1px solid var(--border);
  }

  pre.example-code {
    background: var(--bg-code);
    border: 1px solid var(--border-soft);
    border-radius: 8px;
    padding: 14px 16px;
    overflow-x: auto;
    font-size: 12.5px;
    line-height: 1.55;
    margin: 0;
  }
  pre.example-code code {
    background: transparent;
    padding: 0;
    border: 0;
    color: var(--text);
  }

  .tip {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border-left: 3px solid var(--accent);
    padding: 10px 14px;
    border-radius: 0 6px 6px 0;
    font-size: 13.5px;
    color: var(--text);
    margin: 12px 0 16px;
  }
  .tip code { font-size: 12.5px; }
</style>
